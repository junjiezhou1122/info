+  for (const [key, value] of Object.entries(diff.removed)) out(`  - ${key}: ${JSON.stringify(value)}`);
+  for (const [key, value] of Object.entries(diff.changed)) out(`  ~ ${key}: ${JSON.stringify(value.from)} -> ${JSON.stringify(value.to)}`);
+}
+
